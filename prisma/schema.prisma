generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  passwordHash   String
  plan           String          @default("FREE")
  credits        Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  socialAccounts SocialAccount[]
  posts          Post[]
  clipJobs       ClipJob[]
}

model ClipJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl       String
  sourceTitle     String?
  sourceDuration  Int?
  status          String    @default("QUEUED")
  stage           String?
  stageDetail     String?
  progress        Int       @default(0)
  optCaptions     Boolean   @default(true)
  optMusic        Boolean   @default(true)
  optPunchZooms   Boolean   @default(true)
  /** Cached transcript JSON (segment-level) so re-pick can skip download
    * + transcribe. Stored only after the first successful pipeline run. */
  cachedTranscript String?
  error           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clips           Clip[]

  @@index([userId, createdAt])
  @@index([status])
}

model Clip {
  id               String   @id @default(cuid())
  jobId            String
  job              ClipJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  startSec         Float
  endSec           Float
  durationSec      Float
  hookTitle        String
  hookVariants     String?
  reason           String?
  viralityScore    Int
  transcript       String?
  videoPath        String?
  thumbnailPath    String?
  musicAttribution String?
  posted           Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([jobId])
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  externalId   String?
  username     String?
  avatar       String?
  meta         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model Post {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  caption      String
  mediaUrl     String?
  mediaType    String?
  platforms    String
  status       String    @default("DRAFT")
  results      String?
  scheduledFor DateTime?
  postedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([scheduledFor])
}
