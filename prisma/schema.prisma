generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  passwordHash        String
  plan                String               @default("FREE")
  role                String               @default("USER")
  credits             Int                  @default(0)
  banned              Boolean              @default(false)
  featureFlags        String?
  maxClipsPerMonth    Int?
  notes               String?
  notifyOnPost        Boolean              @default(true)
  weeklyDigestEnabled Boolean              @default(true)
  lastDigestSentAt    DateTime?
  audienceTimezone    String?
  /** Saved publishing prefs — applied when user manually distributes a job
    * (panel pre-fills) AND when clipperAutoPublish is true (auto-trigger
    * after clip rendering completes). */
  clipperAutoPublish     Boolean @default(false)
  clipperPlatforms       String?
  clipperClipsPerDay     Int     @default(1)
  clipperSkipWeekends    Boolean @default(true)
  clipperWithAiHashtags  Boolean @default(true)
  clipperTimezone        String?
  /** Caption style: "classic" (yellow word highlight + black box, default),
    * "bold" (large yellow text, no box), "minimal" (small white text). */
  clipperCaptionStyle    String  @default("bold")
  /** Optional handle/text shown as branded end card on last ~1.5s of each
    * clip (e.g. "@gillpixipace"). Empty/null disables the end card. */
  clipperEndCardText     String?
  /** User's default hashtags (comma-separated, with or without #). Always
    * prepended to AI-generated tags during auto-distribute, deduplicated,
    * capped at platform's max count. Empty = AI tags only. */
  clipperDefaultHashtags String?
  /** Path under .uploads/voices/ to a user-uploaded 5-15s voice clip used
    * as the F5-TTS reference for explainer narration. The clip's prosody +
    * timbre are mimicked, so an energetic reference produces energetic
    * narration. Empty = use F5-TTS's built-in default narrator voice. */
  f5RefAudioPath  String?
  /** Verbatim transcript of f5RefAudioPath. F5-TTS needs this for phoneme
    * alignment during cloning. Required if f5RefAudioPath is set. */
  f5RefAudioText  String?
  /** Email verification — null until the user clicks the link in the
    * verification email. Sensitive ops (post publish, account connect)
    * may gate on this once we want to enforce it. Set to now() on
    * successful click. */
  emailVerified            DateTime?
  /** Random hex token (32 bytes) embedded in the verification email
    * link. Cleared after successful verify or expiry. */
  emailVerifyToken         String?   @unique
  /** Token expiry (24h after issuance). After this, user must request
    * a new email via "Resend verification" button. */
  emailVerifyTokenExpires  DateTime?
  /** Last security-sensitive event timestamp — used by the audit-log
    * worker to detect unusual patterns (multiple resets in an hour,
    * etc). Null = no recent security events. */
  lastSecurityEventAt      DateTime?
  /** Most recent login fingerprint — SHA-256(userAgent) truncated.
    * On the next login, if the new fingerprint differs we send a
    * "new sign-in" alert email. First login on a fresh account also
    * triggers an alert (lastLoginUaHash starts null). */
  lastLoginUaHash          String?
  /** IP of last successful login — surfaced in the alert email so
    * the user can spot impossible-travel attacks ("San Francisco one
    * hour, Bangalore the next"). Stored opportunistically; null when
    * IP couldn't be determined. */
  lastLoginIp              String?
  lastLoginAt              DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  socialAccounts      SocialAccount[]
  posts               Post[]
  clipJobs            ClipJob[]
  passwordResetTokens PasswordResetToken[]
}

/// Append-only log of every action taken from /control-room. Used for
/// security accountability + post-incident investigation. Never deleted.
model AdminAuditLog {
  id          String   @id @default(cuid())
  /// The admin's email at the time of the action (denormalized — admin
  /// identity comes from OWNER_EMAIL env var, not a foreign key).
  adminEmail  String
  /// Action key: e.g. "user.ban", "user.unban", "user.delete",
  /// "user.setPlan", "user.impersonate", "cache.clear", "worker.pause"
  action      String
  /// Subject of the action — usually a userId, but could be a cache key,
  /// job id, etc. Free text.
  targetId    String?
  /// Free-form JSON for action-specific details (old → new values, etc).
  details     String?
  /// Source IP (best-effort — from cf-connecting-ip / x-forwarded-for).
  ip          String?
  createdAt   DateTime @default(now())

  @@index([adminEmail, createdAt])
  @@index([action, createdAt])
  @@index([targetId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ClipJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl       String
  sourceTitle     String?
  sourceDuration  Int?
  status          String    @default("QUEUED")
  stage           String?
  stageDetail     String?
  progress        Int       @default(0)
  /** Pipeline mode: "CLIP" extracts source segments; "EXPLAINER" generates
    * an original narration video using rapid silent source cutaways under
    * AI-narrated commentary (zero source audio = no Content ID match). */
  mode            String    @default("CLIP")
  optCaptions     Boolean   @default(true)
  optMusic        Boolean   @default(true)
  optPunchZooms   Boolean   @default(true)
  optBroll        Boolean   @default(false)
  optTranslateCaptions Boolean @default(false)
  /** Optional free-text guidance from user — appended to the picker prompt
    * so they can steer Gemma ("focus on storytelling", "skip self-promo"). */
  pickerGuidance  String?
  /** Cached transcript JSON (segment-level) so re-pick can skip download
    * + transcribe. Stored only after the first successful pipeline run. */
  cachedTranscript String?
  error           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clips           Clip[]

  @@index([userId, createdAt])
  @@index([status])
}

model Clip {
  id               String   @id @default(cuid())
  jobId            String
  job              ClipJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  startSec         Float
  endSec           Float
  durationSec      Float
  hookTitle        String
  hookVariants     String?
  reason           String?
  viralityScore    Int
  transcript       String?
  videoPath        String?
  thumbnailPath    String?
  musicAttribution String?
  brollMoments     String?
  posted           Boolean  @default(false)
  /** Opt-in public showcase. When true, the clip is viewable at
    * klone.live/c/{id} without auth + the video file is served via
    * /api/public-clips/{id}/* without an owner session. */
  publicShareEnabled Boolean @default(false)
  /** Snapshot view counter for the public page. Bumps on each unique-ish
    * pageview (incremented server-side, not strict-unique). */
  publicViews        Int     @default(0)
  createdAt        DateTime @default(now())

  @@index([jobId])
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  externalId   String?
  username     String?
  avatar       String?
  meta         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model Post {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  caption      String
  mediaUrl     String?
  mediaType    String?
  platforms    String
  status       String    @default("DRAFT")
  results      String?
  /** Per-platform engagement metrics JSON, refreshed on demand from each
    * platform's insights API. Shape: {<platform>: {views, likes, comments, ...}}. */
  metrics          String?
  metricsUpdatedAt DateTime?
  scheduledFor DateTime?
  postedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([scheduledFor])
}
