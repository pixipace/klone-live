generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String               @unique
  passwordHash        String
  plan                String               @default("FREE")
  role                String               @default("USER")
  credits             Int                  @default(0)
  banned              Boolean              @default(false)
  featureFlags        String?
  maxClipsPerMonth    Int?
  notes               String?
  notifyOnPost        Boolean              @default(true)
  audienceTimezone    String?
  /** Saved publishing prefs — applied when user manually distributes a job
    * (panel pre-fills) AND when clipperAutoPublish is true (auto-trigger
    * after clip rendering completes). */
  clipperAutoPublish     Boolean @default(false)
  clipperPlatforms       String?
  clipperClipsPerDay     Int     @default(1)
  clipperSkipWeekends    Boolean @default(true)
  clipperWithAiHashtags  Boolean @default(true)
  clipperTimezone        String?
  /** Caption style: "classic" (yellow word highlight + black box, default),
    * "bold" (large yellow text, no box), "minimal" (small white text). */
  clipperCaptionStyle    String  @default("classic")
  /** Optional handle/text shown as branded end card on last ~1.5s of each
    * clip (e.g. "@gillpixipace"). Empty/null disables the end card. */
  clipperEndCardText     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  socialAccounts      SocialAccount[]
  posts               Post[]
  clipJobs            ClipJob[]
  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model ClipJob {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceUrl       String
  sourceTitle     String?
  sourceDuration  Int?
  status          String    @default("QUEUED")
  stage           String?
  stageDetail     String?
  progress        Int       @default(0)
  optCaptions     Boolean   @default(true)
  optMusic        Boolean   @default(true)
  optPunchZooms   Boolean   @default(true)
  optBroll        Boolean   @default(false)
  optTranslateCaptions Boolean @default(false)
  /** Optional free-text guidance from user — appended to the picker prompt
    * so they can steer Gemma ("focus on storytelling", "skip self-promo"). */
  pickerGuidance  String?
  /** Cached transcript JSON (segment-level) so re-pick can skip download
    * + transcribe. Stored only after the first successful pipeline run. */
  cachedTranscript String?
  /** Path to a generated highlight reel (compilation of top clips), if any. */
  highlightReelPath  String?
  highlightReelThumb String?
  highlightReelHook  String?
  error           String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  clips           Clip[]

  @@index([userId, createdAt])
  @@index([status])
}

model Clip {
  id               String   @id @default(cuid())
  jobId            String
  job              ClipJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  startSec         Float
  endSec           Float
  durationSec      Float
  hookTitle        String
  hookVariants     String?
  reason           String?
  viralityScore    Int
  transcript       String?
  videoPath        String?
  thumbnailPath    String?
  musicAttribution String?
  brollMoments     String?
  posted           Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([jobId])
}

model SocialAccount {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform     String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  externalId   String?
  username     String?
  avatar       String?
  meta         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, platform])
  @@index([userId])
}

model Post {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  caption      String
  mediaUrl     String?
  mediaType    String?
  platforms    String
  status       String    @default("DRAFT")
  results      String?
  scheduledFor DateTime?
  postedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId, createdAt])
  @@index([scheduledFor])
}
